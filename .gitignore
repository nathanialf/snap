# =============================================================================
# IP PROTECTION — DO NOT REMOVE OR LOOSEN THESE RULES WITHOUT REVIEW
# =============================================================================
# This repository must never contain ROM data, extracted assets, or any
# material owned by Nintendo / The Pokémon Company / Creatures Inc. / GAME FREAK.
# The rules below ignore every common ROM and extracted-asset file format.
# If you need to add a real source file whose name happens to collide, prefer
# renaming the file rather than weakening the patterns.
# =============================================================================

# --- ROM images (every common N64 dump format) ---
*.z64
*.n64
*.v64
*.bin
*.rom
baserom*
rom/
roms/

# --- Build outputs that may embed ROM-derived data ---
build/
*.elf
*.o
*.a
*.map
*.ld.tmp

# --- Extracted assets (populated at build time from the user's ROM) ---
assets/**
!assets/.gitkeep
!assets/README.md

# --- Disassembled / split asm (regenerated by splat from the user's ROM) ---
asm/**
!asm/.gitkeep
!asm/README.md
!asm/nonmatchings/  # hand-written non-matching stubs are tracked
asm/nonmatchings/**/*.s.bak

# --- Audio / texture / model dumps ---
*.aifc
*.aiff
*.wav
*.mid
*.seq
*.ctl
*.tbl
*.bnk
*.png.bin
*.rgba16
*.rgba32
*.ia8
*.ia16
*.ci4
*.ci8
*.i4
*.i8

# --- Symbol files and addresses derived from the original ROM ---
# (Symbol *names* invented by us are fine; raw vendor symbol tables are not.)
*.sym.bak

# --- Toolchain / venv / editor noise ---
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.idea/
.vscode/
!.vscode/extensions.json
*.swp
.DS_Store
Thumbs.db

# --- Local config overrides ---
.env
.env.local
config/local.*
expected/

# --- Vendored ultralib (clean-room exception; cloned locally by setup) ---
# See decomp/NOTES.md "ultralib vendoring" section. Not committed; users
# clone decompals/ultralib themselves. Symlinks under src/ that point at
# ultralib sources are tracked, but the ultralib tree itself is not.
lib/ultralib/

# --- decomp-permuter (cloned locally, driven by tools/permute_run.sh) ---
# Upstream: https://github.com/simonlindholm/decomp-permuter. Not committed;
# users clone it themselves into tools/decomp-permuter/. Run artefacts under
# tools/decomp-permuter/runs/ are also covered by this rule.
tools/decomp-permuter/

# --- Agent guidance (kept local; not part of the public project) ---
CLAUDE.md
.claude/
